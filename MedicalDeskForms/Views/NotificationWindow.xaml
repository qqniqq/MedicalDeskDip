<Window x:Class="MedicalDeskForms.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомления"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Grid.Row="0"
                Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Центр уведомлений"
                    Foreground="White"
                    FontSize="36"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <!-- Панель управления -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="5"
                Padding="10"
                Margin="0,10,0,10">

            <WrapPanel>

                <Button x:Name="btnRead"
                        Width="220"
                        Height="35"
                        Margin="5"
                        Content="Отметить как прочитанное"
                        Click="btnRead_Click" FontSize="16"/>

                <Button x:Name="btnRefresh"
                        Width="140"
                        Height="35"
                        Margin="5"
                        Content="Обновить"
                        Click="btnRefresh_Click" FontSize="16"/>

                <TextBlock
                    Margin="30,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    FontSize="16"
                    Text="Двойной щелчок по уведомлению также помечает его как прочитанное"/>

            </WrapPanel>

        </Border>

        <!-- Таблица -->

        <DataGrid x:Name="gridNotifications"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="gridNotifications_MouseDoubleClick" FontSize="18">

            <DataGrid.RowStyle>

                <Style TargetType="DataGridRow">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsRead}"
                                     Value="False">

                            <Setter Property="FontWeight"
                                    Value="Bold"/>

                            <Setter Property="Background"
                                    Value="#FFF8D5"/>

                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsRead}"
                                     Value="True">

                            <Setter Property="Background"
                                    Value="White"/>

                        </DataTrigger>

                    </Style.Triggers>

                </Style>

            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Дата"
                    Width="180"
                    Binding="{Binding NotificationDate,
                    StringFormat=dd.MM.yyyy HH:mm}"/>

                <DataGridTextColumn
                    Header="Тип события"
                    Width="180"
                    Binding="{Binding EventType}"/>

                <DataGridTextColumn
                    Header="Сообщение"
                    Width="*"
                    Binding="{Binding MessageText}"/>

                <DataGridCheckBoxColumn
                    Header="Прочитано"
                    Width="120"
                    Binding="{Binding IsRead}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Низ -->

        <Border Grid.Row="3"
                Background="#E9EDF2">

            <DockPanel Margin="15">

                <Button x:Name="btnBack"
                        Width="120"
                        Height="35"
                        Margin="10"
                        HorizontalAlignment="Left"
                        DockPanel.Dock="Left"
                        Content="Назад"
                        Click="btnBack_Click" FontSize="18"/>
                <TextBlock
                    x:Name="txtInfo"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    Text="Уведомления отображаются автоматически"/>


            </DockPanel>

        </Border>

    </Grid>

</Window>