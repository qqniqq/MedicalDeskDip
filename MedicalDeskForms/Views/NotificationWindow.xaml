<Window x:Class="MedicalDeskForms.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомления"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Уведомления"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

                <Image
                    Width="45"
                    Height="45"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Source="/MedicalDeskForms;component/Resources/logo.png"/>

            </Grid>

        </Border>

        <!-- Кнопки -->

        <WrapPanel Grid.Row="1"
                   Margin="0,10">

            <Button x:Name="btnRead"
                    Width="200"
                    Height="35"
                    Margin="5"
                    Content="Отметить прочитанным"
                    Click="btnRead_Click"/>

            <Button x:Name="btnRefresh"
                    Width="120"
                    Height="35"
                    Margin="5"
                    Content="Обновить"
                    Click="btnRefresh_Click"/>

        </WrapPanel>

        <!-- Таблица -->

        <DataGrid
    x:Name="gridNotifications"
    AutoGenerateColumns="False"
    IsReadOnly="True"
    MouseDoubleClick="gridNotifications_MouseDoubleClick">

            <DataGrid.Columns>

                <DataGridTextColumn
            Header="Дата"
            Width="170"
            Binding="{Binding NotificationDate,
            StringFormat=dd.MM.yyyy HH:mm}"/>

                <DataGridTextColumn
            Header="Тип"
            Width="150"
            Binding="{Binding EventType}"/>

                <DataGridTextColumn
            Header="Сообщение"
            Width="*"
            Binding="{Binding MessageText}"/>

                <DataGridCheckBoxColumn
            Header="Прочитано"
            Width="120"
            Binding="{Binding IsRead}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Низ -->

        <Border Grid.Row="3"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="15,0">

                <Button x:Name="btnBack"
                        Width="120"
                        Height="35"
                        Content="Назад"
                        Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>