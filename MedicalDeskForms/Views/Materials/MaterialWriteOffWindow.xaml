<Window x:Class="MedicalDeskForms.Views.Materials.MaterialWriteOffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Списание расходника"
        Width="700"
        Height="550"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Списание расходника"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <StackPanel Grid.Row="1"
                    Margin="10">

            <TextBlock Text="Расходник" FontSize="16"/>

            <ComboBox
                x:Name="cmbMaterial"
                Height="35"
                Margin="0,5,0,15" FontSize="14"/>

            <TextBlock Text="Количество" FontSize="16"/>

            <TextBox
                x:Name="txtQuantity"
                Height="35"
                Margin="0,5,0,15" FontSize="14"/>

            <TextBlock Text="Причина списания" FontSize="16"/>

            <TextBox
                x:Name="txtReason"
                Height="120"
                TextWrapping="Wrap"
                AcceptsReturn="True" FontSize="14"/>

        </StackPanel>

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        Margin="15,0"
                        VerticalAlignment="Center">

                <Button
                    Width="150"
                    Height="35"
                    Margin="5"
                    Content="Списать"
                    Click="btnSave_Click" TextBlock.FontSize="16"/>

                <Button
                    Width="120"
                    Height="35"
                    Margin="5"
                    Content="Назад"
                    Click="btnBack_Click" TextBlock.FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>