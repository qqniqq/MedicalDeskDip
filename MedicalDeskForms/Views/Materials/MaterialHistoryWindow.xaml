<Window x:Class="MedicalDeskForms.Views.Materials.MaterialHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История расходников"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="История движения расходных материалов"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <!-- Таблица -->

        <DataGrid x:Name="gridHistory"
          Grid.Row="1"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Margin="0,10,0,10" FontSize="16">

            <DataGrid.Columns>

                <DataGridTextColumn
            Header="Дата"
            Width="170"
            Binding="{Binding OperationDate,
            StringFormat=dd.MM.yyyy HH:mm}"/>

                <DataGridTextColumn
            Header="Материал"
            Width="220"
            Binding="{Binding MaterialName}"/>

                <DataGridTextColumn
            Header="Пользователь"
            Width="250"
            Binding="{Binding SpecialistName}"/>

                <DataGridTextColumn
            Header="Заявка"
            Width="120"
            Binding="{Binding RequestId}"/>

                <DataGridTextColumn
            Header="Количество"
            Width="120"
            Binding="{Binding Quantity}"/>

                <DataGridTextColumn
            Header="Комментарий"
            Width="*"
            Binding="{Binding WriteOffReason}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Низ -->

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="15,0">

                <Button x:Name="btnBack"
                        Width="120"
                        Height="35"
                        Content="Назад"
                        Click="btnBack_Click" FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>