<Window x:Class="MedicalDeskForms.Views.Materials.MaterialListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Расходные материалы"
        Width="1300"
        Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico" WindowStyle="ThreeDBorderWindow">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Расходные материалы"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

                <Image
                    Width="45"
                    Height="45"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Source="/MedicalDeskForms;component/Resources/logo.png"/>

            </Grid>

        </Border>

        <WrapPanel Grid.Row="1"
                   Margin="0,10">
            <Button x:Name="btnAll"
      Width="130"
      Height="35"
      Margin="5"
      Content="Все"
      Click="btnAll_Click"/>
            <Button x:Name="btnLowStock"
           Width="180"
           Height="35"
           Margin="5"
           Content="Минимальный остаток"
           Click="btnLowStock_Click"/>

            <Button x:Name="btnAdd"
                    Width="130"
                    Height="35"
                    Margin="5"
                    Content="Добавить"
                    Click="btnAdd_Click"/>

            <Button x:Name="btnEdit"
                    Width="130"
                    Height="35"
                    Margin="5"
                    Content="Изменить"
                    Click="btnEdit_Click"/>

            <Button x:Name="btnDelete"
                    Width="130"
                    Height="35"
                    Margin="5"
                    Content="Удалить"
                    Click="btnDelete_Click"/>

            <Button x:Name="btnIncome"
                    Width="130"
                    Height="35"
                    Margin="5"
                    Content="Пополнить"
                    Click="btnIncome_Click"/>

            <Button x:Name="btnHistory"
                    Width="130"
                    Height="35"
                    Margin="5"
                    Content="История"
                    Click="btnHistory_Click"/>

         

        </WrapPanel>

        <DataGrid x:Name="gridMaterials"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Код"
                    Width="80"
                    Binding="{Binding Id}"/>

                <DataGridTextColumn
                    Header="Наименование"
                    Width="250"
                    Binding="{Binding Name}"/>

                <DataGridTextColumn
                    Header="Категория"
                    Width="200"
                    Binding="{Binding CategoryName}"/>

                <DataGridTextColumn
                    Header="Количество"
                    Width="120"
                    Binding="{Binding Quantity}"/>

                <DataGridTextColumn
                    Header="Минимум"
                    Width="120"
                    Binding="{Binding MinimumQuantity}"/>

                <DataGridTextColumn
                    Header="Дата поступления"
                    Width="170"
                    Binding="{Binding ReceiptDate,
                    StringFormat=dd.MM.yyyy}"/>

                <DataGridTextColumn
                    Header="Примечание"
                    Width="*"
                    Binding="{Binding Notes}"/>

            </DataGrid.Columns>

        </DataGrid>

        <Border Grid.Row="3"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="15,0">

                <Button x:Name="btnBack"
                        Width="120"
                        Height="35"
                        Content="Назад"
                        Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>