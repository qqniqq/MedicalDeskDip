<Window x:Class="MedicalDeskForms.Views.Materials.MaterialEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Материал"
        Width="700"
        Height="671"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Карточка материала"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <ScrollViewer Grid.Row="1">

            <StackPanel Margin="10">

                <TextBlock Text="Наименование" FontSize="16"/>

                <TextBox
                    x:Name="txtName"
                    Height="35"
                    Margin="0,5,0,10" FontSize="14"/>

                <TextBlock Text="Категория" FontSize="16"/>

                <ComboBox
                    x:Name="cmbCategory"
                    Height="35"
                    Margin="0,5,0,10" TextBlock.FontSize="14"/>

                <TextBlock Text="Количество" FontSize="16"/>

                <TextBox
                    x:Name="txtQuantity"
                    Height="35"
                    Margin="0,5,0,10" TextBlock.FontSize="14"/>

                <TextBlock Text="Минимальный остаток" FontSize="16"/>

                <TextBox
                    x:Name="txtMinimum"
                    Height="35"
                    Margin="0,5,0,10" TextBlock.FontSize="14"/>

                <TextBlock Text="Дата поступления" FontSize="16"/>

                <DatePicker
                    x:Name="dpReceiptDate"
                    Margin="0,5,0,10" TextBlock.FontSize="14"/>

                <TextBlock Text="Примечание" FontSize="16"/>

                <TextBox
                    x:Name="txtNotes"
                    Height="90"
                    AcceptsReturn="True"
                    TextWrapping="Wrap" TextBlock.FontSize="14"/>

            </StackPanel>

        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button x:Name="btnSave"
                        Width="140"
                        Height="35"
                        Margin="5"
                        Content="Сохранить"
                        Click="btnSave_Click" FontSize="16"/>

                <Button x:Name="btnCancel"
                        Width="140"
                        Height="35"
                        Margin="5"
                        Content="Отмена"
                        Click="btnCancel_Click" FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>