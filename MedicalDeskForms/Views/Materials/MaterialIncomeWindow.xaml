<Window x:Class="MedicalDeskForms.Views.Materials.MaterialIncomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пополнение склада"
        Width="600"
        Height="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Пополнение склада"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <StackPanel Grid.Row="1"
                    Margin="10">

            <TextBlock Text="Количество"/>

            <TextBox x:Name="txtQuantity"
                     Height="35"
                     Margin="0,5,0,15"/>

            <TextBlock Text="Комментарий"/>

            <TextBox x:Name="txtComment"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

        </StackPanel>

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        Margin="15,0"
                        VerticalAlignment="Center">

                <Button Content="Сохранить"
                        Width="150"
                        Height="35"
                        Margin="5"
                        Click="btnSave_Click"/>

                <Button Content="Назад"
                        Width="120"
                        Height="35"
                        Margin="5"
                        Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>