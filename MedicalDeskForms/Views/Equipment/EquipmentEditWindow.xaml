<Window x:Class="MedicalDeskForms.Views.Equipment.EquipmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оборудование"
        Width="900"
        Height="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    x:Name="txtTitle"
                    Text="Добавление оборудования"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

                <Image
                    Width="45"
                    Height="45"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Source="/MedicalDeskForms;component/Resources/logo.png"/>

            </Grid>

        </Border>

        <!-- Контент -->

        <ScrollViewer Grid.Row="1">

            <StackPanel Margin="10">

                <TextBlock Text="Инвентарный номер"/>

                <TextBox
                    x:Name="txtInventory"
                    Height="35"
                    Margin="0,5,0,15"
                    IsReadOnly="True"
                    Background="#E9EDF2"/>

                <TextBlock Text="Наименование оборудования"/>

                <TextBox
                    x:Name="txtName"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Модель"/>

                <TextBox
                    x:Name="txtModel"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Серийный номер"/>

                <TextBox
                    x:Name="txtSerial"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Производитель"/>

                <TextBox
                    x:Name="txtManufacturer"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Кабинет"/>

                <TextBox
                    x:Name="txtRoom"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Ответственный пользователь"/>

                <ComboBox
                    x:Name="cmbUser"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Дата ввода в эксплуатацию"/>

                <DatePicker
                    x:Name="dpCommissioningDate"
                    Height="35"
                    Margin="0,5,0,15"/>

                <TextBlock Text="Состояние"/>
                <ComboBox
    x:Name="cmbState"
    Height="35"
    Margin="0,5,0,15"/>

                <TextBlock Text="Примечание"/>

                <TextBox
    x:Name="txtNotes"
    Height="120"
    Margin="0,5,0,15"
    TextWrapping="Wrap"
    AcceptsReturn="True"
    VerticalScrollBarVisibility="Auto"/>

            </StackPanel>

        </ScrollViewer>

        <!-- Низ -->

        <Border Grid.Row="2"
        Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="15,0">

                <Button
            x:Name="btnSave"
            Width="150"
            Height="35"
            Margin="5"
            Content="Сохранить"
            Click="btnSave_Click"/>

                <Button
            x:Name="btnBack"
            Width="120"
            Height="35"
            Margin="5"
            Content="Назад"
            Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>