<Window x:Class="MedicalDeskForms.Views.Equipment.EquipmentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оборудование"
        Width="1400"
        Height="800"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <WrapPanel>

            <TextBox x:Name="txtSearch"
                     Width="250"
                     Height="35"
                     Margin="5"/>

            <Button Content="Добавить"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="btnAdd_Click"/>

            <Button Content="Редактировать"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="btnEdit_Click"/>

            <Button Content="История"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="btnHistory_Click"/>

            <Button Content="Удалить"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="btnDelete_Click"/>

        </WrapPanel>

        <DataGrid x:Name="gridEquipment"
                  Grid.Row="1"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Инв. номер"
                    Binding="{Binding InventoryNumber}"/>

                <DataGridTextColumn
                    Header="Наименование"
                    Binding="{Binding EquipmentName}"/>

                <DataGridTextColumn
                    Header="Модель"
                    Binding="{Binding Model}"/>

                <DataGridTextColumn
                    Header="Производитель"
                    Binding="{Binding Manufacturer}"/>

                <DataGridTextColumn
                    Header="Кабинет"
                    Binding="{Binding RoomNumber}"/>

                <DataGridTextColumn
                    Header="Пользователь"
                    Binding="{Binding UserName}"/>

                <DataGridTextColumn
                    Header="Состояние"
                    Binding="{Binding StateName}"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Window>