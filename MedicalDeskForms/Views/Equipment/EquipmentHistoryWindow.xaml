<Window x:Class="MedicalDeskForms.Views.Equipment.EquipmentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История оборудования"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="История обслуживания оборудования"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

                <Image
                    Width="45"
                    Height="45"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,0"
                    Source="/MedicalDeskForms;component/Resources/logo.png"/>

            </Grid>

        </Border>

        <!-- Таблица -->

        <DataGrid x:Name="gridHistory"
                  Grid.Row="1"
                  Margin="0,10,0,10"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Дата"
                    Width="170"
                    Binding="{Binding ServiceDate,
                    StringFormat=dd.MM.yyyy HH:mm}"/>

                <DataGridTextColumn
                    Header="Тип обслуживания"
                    Width="220"
                    Binding="{Binding ServiceType}"/>

                <DataGridTextColumn
                    Header="Специалист"
                    Width="250"
                    Binding="{Binding SpecialistName}"/>

                <DataGridTextColumn
                    Header="Описание работ"
                    Width="*"
                    Binding="{Binding Description}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Низ -->

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="15,0">

                <Button
                    Width="120"
                    Height="35"
                    Content="Назад"
                    Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>