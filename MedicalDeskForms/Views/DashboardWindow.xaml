<Window x:Class="MedicalDeskForms.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель управления"
        Background="#F5F7FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,15">

            <Border Width="220"
                    Height="120"
                    Margin="5"
                    Background="#FFFFFF">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock
                        Text="Всего заявок"
                        FontSize="18"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        x:Name="txtRequests"
                        FontSize="34"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Width="220"
                    Height="120"
                    Margin="5"
                    Background="#FFFFFF">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock
                        Text="В работе"
                        FontSize="18"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        x:Name="txtInWork"
                        FontSize="34"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Width="220"
                    Height="120"
                    Margin="5"
                    Background="#FFFFFF">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock
                        Text="Завершено"
                        FontSize="18"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        x:Name="txtCompleted"
                        FontSize="34"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Width="220"
                    Height="120"
                    Margin="5"
                    Background="#FFFFFF">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock
                        Text="Критический остаток"
                        FontSize="18"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"/>

                    <TextBlock
                        x:Name="txtLowStock"
                        FontSize="34"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </WrapPanel>

        <GroupBox Grid.Row="1"
                  Header="Материалы с минимальным остатком"
                  Margin="0,0,0,10">

            <DataGrid x:Name="gridLowStock"
                      AutoGenerateColumns="True"
                      Height="250"/>

        </GroupBox>

    </Grid>

</Window>