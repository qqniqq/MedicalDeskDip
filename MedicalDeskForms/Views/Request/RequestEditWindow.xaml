<Window x:Class="MedicalDeskForms.Views.Requests.RequestEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание заявки"
        Width="800"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Создание заявки"
                    Foreground="White"
                    FontSize="24"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <!-- Контент -->

        <ScrollViewer Grid.Row="1">

            <StackPanel Margin="10">

                <TextBlock
                    Text="Кабинет" FontSize="16"/>

                <TextBox
                    x:Name="txtRoom"
                    Height="35"
                    Margin="0,5,0,15" FontSize="14"/>

                <!-- Для администратора и специалиста -->

                <StackPanel
                    x:Name="panelUser">

                    <TextBlock
                        Text="Пользователь" FontSize="16"/>

                    <ComboBox
                        x:Name="cmbUser"
                        Height="35"
                        Margin="0,5,0,15"
                        SelectionChanged="cmbUser_SelectionChanged" FontSize="14"/>

                    <TextBlock
                        Text="Телефон" FontSize="16"/>

                    <TextBox
                        x:Name="txtPhone"
                        Height="35"
                        Margin="0,5,0,15"
                        IsReadOnly="True" FontSize="14"/>

                </StackPanel>

                <TextBlock
                    Text="Тип обращения" FontSize="16"/>

                <ComboBox
                    x:Name="cmbType"
                    Height="35"
                    Margin="0,5,0,15" FontSize="14"/>

                <TextBlock
                    Text="Описание проблемы" FontSize="16"/>

                <TextBox
                    x:Name="txtDescription"
                    Height="220"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" FontSize="14"/>

            </StackPanel>

        </ScrollViewer>

        <!-- Низ -->

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        Margin="15,0"
                        VerticalAlignment="Center">

                <Button
                    x:Name="btnSave"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Content="Сохранить"
                    Click="btnSave_Click" FontSize="16"/>

                <Button
                    x:Name="btnBack"
                    Width="120"
                    Height="35"
                    Margin="5"
                    Content="Назад"
                    Click="btnBack_Click" FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>