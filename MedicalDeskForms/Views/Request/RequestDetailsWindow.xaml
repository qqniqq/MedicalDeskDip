<Window x:Class="MedicalDeskForms.Views.Requests.RequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка заявки"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D"
                Grid.Row="0">

            <Grid>

                <TextBlock
                    Text="Карточка заявки"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="White"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="2*" />

                <ColumnDefinition Width="*" />

            </Grid.ColumnDefinitions>

            <ScrollViewer>

                <StackPanel Margin="10">

                    <TextBlock Text="Номер заявки" FontSize="16"/>
                    <TextBox x:Name="txtNumber"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Кабинет" FontSize="16"/>
                    <TextBox x:Name="txtRoom"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Заявитель" FontSize="16"/>
                    <TextBox x:Name="txtApplicant"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Телефон" FontSize="16"/>
                    <TextBox x:Name="txtPhone"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Тип обращения" FontSize="16"/>
                    <TextBox x:Name="txtType"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Статус" FontSize="16"/>
                    <TextBox x:Name="txtStatus"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Исполнитель" FontSize="16"/>
                    <TextBox x:Name="txtExecutor"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Дата создания" FontSize="16"/>
                    <TextBox x:Name="txtCreated"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Дата принятия" FontSize="16"/>
                    <TextBox x:Name="txtAccepted"
                             IsReadOnly="True" TextBlock.FontSize="16"/>

                    <TextBlock Text="Дата завершения" FontSize="16"/>
                    <TextBox x:Name="txtCompleted"
                             IsReadOnly="True"/>

                    <TextBlock Text="Описание проблемы" FontSize="16"/>

                    <TextBox x:Name="txtDescription"
                             Height="150"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Комментарий специалиста"/>

                    <TextBox x:Name="txtComment"
                             Height="120"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <WrapPanel Margin="0,10">

                        <Button x:Name="btnTake"
            Width="150"
            Content="В работу"
            Click="btnTake_Click"/>

                        <Button x:Name="btnComplete"
            Width="150"
            Content="Завершить"
            Click="btnComplete_Click"/>

                        <Button x:Name="btnWriteOff"
            Width="180"
            Content="Списать расходник"
            Click="btnWriteOff_Click"/>

                        <Button x:Name="btnCancel"
            Width="150"
            Content="Отменить"
            Click="btnCancel_Click"/>

                    </WrapPanel>

                </StackPanel>

            </ScrollViewer>

            <GroupBox Grid.Column="1"
                      Header="История изменений"
                      Margin="10">

                <DataGrid
                    x:Name="gridHistory"
                    AutoGenerateColumns="False"
                    IsReadOnly="True" FontSize="14">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Header="Дата"
                            Width="170"
                            Binding="{Binding EventDate,
                            StringFormat=dd.MM.yyyy HH:mm}"/>

                        <DataGridTextColumn
                            Header="Событие"
                            Width="180"
                            Binding="{Binding EventType}"/>

                        <DataGridTextColumn
                            Header="Описание"
                            Width="*"
                            Binding="{Binding Description}"/>

                        <DataGridTextColumn
                            Header="Пользователь"
                            Width="180"
                            Binding="{Binding UserName}"/>

                    </DataGrid.Columns>

                </DataGrid>

            </GroupBox>

        </Grid>

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="15,0">

                <Button x:Name="btnBack"
                        Width="120"
                        Content="Назад"
                        Click="btnBack_Click" FontSize="16"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>