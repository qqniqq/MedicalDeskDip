<Window x:Class="MedicalDeskForms.Views.Users.UserListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователи"
        Width="1400"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <TextBlock
                Text="Управление пользователями"
                Foreground="White"
                FontSize="36"
                FontWeight="Bold"
                VerticalAlignment="Center"
                Margin="20,0,0,0"/>

        </Border>

        <Grid Grid.Row="1"
              Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <WrapPanel>

                <Grid Width="320"
          Height="35"
          Margin="5">

                    <TextBox
            x:Name="txtSearch"
            VerticalContentAlignment="Center"
            Padding="10,0,10,0"
            TextChanged="txtSearch_TextChanged"/>

                    <TextBlock
            x:Name="txtWatermark"
            Text="Поиск: ФИО, логин, телефон, роль..."
            Foreground="Gray"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            IsHitTestVisible="False" FontSize="16"/>

                </Grid>

                <Button
        x:Name="btnAdd"
        Width="150"
        Height="35"
        Margin="5"
        Content="Добавить"
        Click="btnAdd_Click" TextBlock.FontSize="16"/>

                <Button
        x:Name="btnEdit"
        Width="150"
        Height="35"
        Margin="5"
        Content="Редактировать"
        Click="btnEdit_Click" TextBlock.FontSize="16"/>

                <Button
        x:Name="btnDelete"
        Width="150"
        Height="35"
        Margin="5"
        Content="Удалить"
        Click="btnDelete_Click" TextBlock.FontSize="16"/>

                <Button
        x:Name="btnBlock"
        Width="180"
        Height="35"
        Margin="5"
        Content="Блокировать"
        Click="btnBlock_Click" TextBlock.FontSize="16"/>

                <Button
        x:Name="btnResetPassword"
        Width="180"
        Height="35"
        Margin="5"
        Content="Сбросить пароль"
        Click="btnResetPassword_Click" TextBlock.FontSize="16"/>

                <Button
        x:Name="btnRefresh"
        Width="150"
        Height="35"
        Margin="5"
        Content="Обновить"
        Click="btnRefresh_Click" TextBlock.FontSize="16"/>

            </WrapPanel>

            <DataGrid
                x:Name="gridUsers"
                Grid.Row="1"
                Margin="0,10,0,0"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionChanged="gridUsers_SelectionChanged" FontSize="16">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="ID"
                        Binding="{Binding Id}"
                        Width="70"/>

                    <DataGridTextColumn
                        Header="ФИО"
                        Binding="{Binding FullName}"
                        Width="300"/>

                    <DataGridTextColumn
                        Header="Телефон"
                        Binding="{Binding Phone}"
                        Width="180"/>

                    <DataGridTextColumn
                        Header="Логин"
                        Binding="{Binding Login}"
                        Width="150"/>

                    <DataGridTextColumn
                        Header="Роль"
                        Binding="{Binding RoleName}"
                        Width="170"/>

                    <DataGridCheckBoxColumn
                        Header="Активен"
                        Binding="{Binding IsActive}"
                        Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

        <Border Grid.Row="2"
                Background="#E6EAF0">

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="15,0">

                <Button
                    Width="120"
                    Height="35"
                    Content="Назад"
                    Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>