<Window x:Class="MedicalDeskForms.Views.Reports.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Icon="/MedicalDeskForms;component/Resources/icon.ico">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#0A2E5D">

            <Grid>

                <TextBlock
                    Text="Отчеты"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="24"
                    VerticalAlignment="Center"
                    Margin="20,0,0,0"/>

            </Grid>

        </Border>

        <WrapPanel Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">

            <Button x:Name="btnRequestsReport"
                    Width="250"
                    Height="60"
                    Margin="10"
                    Content="Отчет по заявкам"
                    Click="btnRequestsReport_Click"/>

            <Button x:Name="btnMaterialsReport"
                    Width="250"
                    Height="60"
                    Margin="10"
                    Content="Отчет по расходникам"
                    Click="btnMaterialsReport_Click"/>

            <Button x:Name="btnAuditReport"
                    Width="250"
                    Height="60"
                    Margin="10"
                    Content="Журнал действий"
                    Click="btnAuditReport_Click"/>

        </WrapPanel>

        <Border Grid.Row="2"
                Background="#E9EDF2">

            <StackPanel Orientation="Horizontal"
                        Margin="15,0"
                        VerticalAlignment="Center">

                <Button Width="120"
                        Height="35"
                        Content="Назад"
                        Click="btnBack_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>